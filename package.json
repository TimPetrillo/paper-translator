{
  "name": "paper-translator",
  "version": "0.1.0",
  "private": true,
  "description": "A privacy-first academic paper translator for Chrome and Edge.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "npm run build && node scripts/package.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^9.39.2",
    "@types/chrome": "^0.2.0",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fflate": "^0.8.3",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.5"
  }
}
